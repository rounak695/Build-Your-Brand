# ──────────────────────────────────────────────────────
# AI Brand Builder — Architecture v2.0 Environment
# ──────────────────────────────────────────────────────

# Supabase — Database + Auth
PUBLIC_SUPABASE_URL="your_supabase_url"
PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"

# OpenAI — GPT-4o (Context/Inspiration), gpt-image-1 (Logos/Assets), text-embedding-3-small (Vectors)
OPENAI_API_KEY="your_openai_api_key"

# Google AI — Gemini 2.5 Pro (Chat/Names/Guidelines), nano-banana-pro (Moodboards/Social)
GOOGLE_AI_API_KEY="your_google_ai_api_key"

# Anthropic — Claude Opus 4.6 (React Wireframes), Claude Haiku (Decision Routing)
ANTHROPIC_API_KEY="your_anthropic_api_key"

# Cloudflare R2 — Asset Storage
R2_ACCOUNT_ID="your_r2_account_id"
R2_ACCESS_KEY_ID="your_r2_access_key_id"
R2_SECRET_ACCESS_KEY="your_r2_secret_access_key"
R2_BUCKET_NAME="brand-assets"
R2_PUBLIC_URL="your_r2_public_url"

# Upstash Redis — Job Queue & Rate Limiting
UPSTASH_REDIS_URL="your_upstash_redis_url"
UPSTASH_REDIS_TOKEN="your_upstash_redis_token"

# Stripe — Payments (PAUSED)
# STRIPE_SECRET_KEY="your_stripe_secret_key"
# STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"
# PUBLIC_STRIPE_PUBLISHABLE_KEY="your_stripe_publishable_key"
